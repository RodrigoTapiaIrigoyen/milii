# =============================================
# LuxProfile MX — Variables de Entorno (EJEMPLO)
# =============================================
# Copia este archivo a .env.local y rellena los valores

# MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/luxprofile?retryWrites=true&w=majority&appName=luxprofile

# JWT Secret — OBLIGATORIO. Genera uno con: openssl rand -hex 32
JWT_SECRET=

# MercadoPago
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR_xxxxxxxxxxxx
MERCADOPAGO_ACCESS_TOKEN=APP_USR_xxxxxxxxxxxx
# Secret del webhook (Panel MP → Tu integración → Webhooks → Clave secreta)
MERCADOPAGO_WEBHOOK_SECRET=

# Resend (emails transaccionales) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=LuxProfile <noreply@luxprofile.mx>

# Cloudinary (fotos) — https://cloudinary.com
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
